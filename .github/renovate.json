{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^services/slides/index\\.html$/"
      ],
      "matchStrings": [
        "cdn\\.jsdelivr\\.net/npm/(?<depName>reveal\\.js)@(?<currentValue>[0-9.]+)/"
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^services/booking/custom/build\\.gradle\\.kts$/",
        "/^\\.github/workflows/build\\.yml$/"
      ],
      "matchStrings": [
        "jvmToolchain\\((?<currentValue>\\d+)\\)",
        "java-version:\\s*['\"](?<currentValue>\\d+)['\"]"
      ],
      "depNameTemplate": "java",
      "datasourceTemplate": "java-version"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base images"
    },
    {
      "matchManagers": ["gradle", "gradle-wrapper"],
      "groupName": "Kotlin/Gradle dependencies"
    },
    {
      "matchPackageNames": ["eclipse-temurin", "java"],
      "matchUpdateTypes": ["major"],
      "groupName": "Java toolchain major upgrade"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["java"],
      "matchUpdateTypes": ["minor", "patch"],
      "enabled": false
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["reveal.js"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "reveal.js"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["reveal.js"],
      "matchUpdateTypes": ["major"],
      "groupName": "reveal.js (major)",
      "dependencyDashboardApproval": true
    }
  ]
}
