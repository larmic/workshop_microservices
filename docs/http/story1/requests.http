### ===========================
### Backend Services - Data
### ===========================

### Flight Service - List Flights
GET http://{{host}}:{{flightPort}}/flights

> {%
    client.test("Flights status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Flights returns 3 entries", function () {
        client.assert(response.body.length === 3, "Expected 3 flights");
    });
    client.test("Flight has required fields", function () {
        var flight = response.body[0];
        client.assert(flight.id !== undefined, "Expected id");
        client.assert(flight.origin !== undefined, "Expected origin");
        client.assert(flight.destination !== undefined, "Expected destination");
        client.assert(flight.price !== undefined, "Expected price");
        client.assert(flight.currency !== undefined, "Expected currency");
    });
%}

### Hotel Service - List Hotels
GET http://{{host}}:{{hotelPort}}/hotels

> {%
    client.test("Hotels status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Hotels returns 3 entries", function () {
        client.assert(response.body.length === 3, "Expected 3 hotels");
    });
    client.test("Hotel has required fields", function () {
        var hotel = response.body[0];
        client.assert(hotel.id !== undefined, "Expected id");
        client.assert(hotel.name !== undefined, "Expected name");
        client.assert(hotel.price !== undefined, "Expected price");
        client.assert(hotel.currency !== undefined, "Expected currency");
        client.assert(hotel.unit !== undefined, "Expected unit");
    });
%}

### Car Service - List Cars
GET http://{{host}}:{{carPort}}/cars

> {%
    client.test("Cars status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Cars returns 3 entries", function () {
        client.assert(response.body.length === 3, "Expected 3 cars");
    });
    client.test("Car has required fields", function () {
        var car = response.body[0];
        client.assert(car.id !== undefined, "Expected id");
        client.assert(car.model !== undefined, "Expected model");
        client.assert(car.price !== undefined, "Expected price");
        client.assert(car.currency !== undefined, "Expected currency");
        client.assert(car.unit !== undefined, "Expected unit");
    });
%}

### ===========================
### BookingService Story 1
### ===========================

### Booking Service - Health Check
GET http://{{host}}:{{bookingPort}}/health

> {%
    client.test("Booking health status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Booking health status is UP", function () {
        client.assert(response.body.status === "UP", "Expected status UP");
    });
%}

### Booking Service - Configuration Info
GET http://{{host}}:{{bookingPort}}/info

> {%
    client.test("Info status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Info contains service URLs", function () {
        client.assert(response.body.flightServiceUrl !== undefined, "Expected flightServiceUrl");
        client.assert(response.body.hotelServiceUrl !== undefined, "Expected hotelServiceUrl");
        client.assert(response.body.carServiceUrl !== undefined, "Expected carServiceUrl");
    });
    client.test("Info contains timeout and profile", function () {
        client.assert(response.body.timeout !== undefined, "Expected timeout");
        client.assert(response.body.activeProfile !== undefined, "Expected activeProfile");
    });
%}

### Booking Service - Combined Booking Offers
GET http://{{host}}:{{bookingPort}}/booking/offers

> {%
    client.test("Booking offers status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Response contains flights, hotels, cars", function () {
        client.assert(response.body.flights !== undefined, "Expected flights");
        client.assert(response.body.hotels !== undefined, "Expected hotels");
        client.assert(response.body.cars !== undefined, "Expected cars");
    });
    client.test("Each category has 3 entries", function () {
        client.assert(response.body.flights.length === 3, "Expected 3 flights");
        client.assert(response.body.hotels.length === 3, "Expected 3 hotels");
        client.assert(response.body.cars.length === 3, "Expected 3 cars");
    });
%}

### Booking Service - OpenAPI Specification
GET http://{{host}}:{{bookingPort}}/openapi

> {%
    client.test("OpenAPI status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("OpenAPI response is YAML", function () {
        client.assert(response.contentType.mimeType === "application/yaml", "Expected application/yaml");
    });
%}
