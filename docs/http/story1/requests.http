### ===========================
### Backend Services - Health
### ===========================

### Flight Service - Health Check
GET http://{{host}}:{{flightPort}}/health

> {%
    client.test("Flight health status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Flight health status is UP", function () {
        client.assert(response.body.status === "UP", "Expected status UP");
    });
%}

