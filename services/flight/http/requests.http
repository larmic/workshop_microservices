### ===========================
### FlightService
### ===========================

### Flight Service - Buchung erstellen
POST http://{{host}}:{{flightPort}}/bookings
Content-Type: application/json

{
  "flightId": "LH123",
  "customerName": "Max Mustermann"
}

> {%
    client.test("Booking status is 201", function () {
        client.assert(response.status === 201, "Expected 201");
    });
    client.test("Booking has bookingId", function () {
        client.assert(response.body.bookingId !== undefined, "Expected bookingId");
    });
    client.global.set("bookingId", response.body.bookingId);
%}

### Flight Service - Buchung stornieren (Kompensation)
DELETE http://{{host}}:{{flightPort}}/bookings/{{bookingId}}

> {%
    client.test("Cancel status is 204", function () {
        client.assert(response.status === 204, "Expected 204");
    });
%}

### Flight Service - Stornierung wiederholen (idempotent)
DELETE http://{{host}}:{{flightPort}}/bookings/{{bookingId}}

> {%
    client.test("Repeated cancel still 204", function () {
        client.assert(response.status === 204, "Expected 204");
    });
%}

### Flight Service - Stornierung mit unbekannter ID (idempotent)
DELETE http://{{host}}:{{flightPort}}/bookings/F-deadbe

> {%
    client.test("Unknown id cancel still 204", function () {
        client.assert(response.status === 204, "Expected 204");
    });
%}
