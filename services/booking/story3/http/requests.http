### ===========================
### BookingService Story 3
### ===========================

### Booking Service - Health Check
GET http://{{host}}:{{bookingPort}}/health

> {%
    client.test("Booking health status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Booking health status is UP", function () {
        client.assert(response.body.status === "UP", "Expected status UP");
    });
%}

### Booking Service - Configuration Info
GET http://{{host}}:{{bookingPort}}/info

> {%
    client.test("Info status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Info contains service URLs", function () {
        client.assert(response.body.consulUrl !== undefined, "Expected consulUrl");
    });
    client.test("Info contains timeout and profile", function () {
        client.assert(response.body.timeout !== undefined, "Expected timeout");
        client.assert(response.body.activeProfile !== undefined, "Expected activeProfile");
    });
%}

### Booking Service - Combined Booking Offers
GET http://{{host}}:{{bookingPort}}/booking/offers

> {%
    client.test("Booking offers status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Response contains flights, hotels, cars", function () {
        client.assert(response.body.flights !== undefined, "Expected flights");
        client.assert(response.body.hotels !== undefined, "Expected hotels");
        client.assert(response.body.cars !== undefined, "Expected cars");
    });
    client.test("Each category has 3 entries", function () {
        client.assert(response.body.flights.length === 3, "Expected 3 flights");
        client.assert(response.body.hotels.length === 3, "Expected 3 hotels");
        client.assert(response.body.cars.length === 3, "Expected 3 cars");
    });
%}

### Booking Service - Create Combined Booking
POST http://{{host}}:{{bookingPort}}/booking/bookings
Content-Type: application/json

{
  "flightId": "LH123",
  "hotelId": "H1",
  "carId": "C1",
  "customerName": "Max Mustermann"
}

> {%
    client.test("Booking status is 201", function () {
        client.assert(response.status === 201, "Expected 201");
    });
    client.test("Response contains bookingId and customerName", function () {
        client.assert(response.body.bookingId !== undefined, "Expected bookingId");
        client.assert(response.body.customerName === "Max Mustermann", "Expected customerName Max Mustermann");
    });
    client.test("Response contains flight, hotel, car confirmations", function () {
        client.assert(response.body.flight !== undefined, "Expected flight");
        client.assert(response.body.hotel !== undefined, "Expected hotel");
        client.assert(response.body.car !== undefined, "Expected car");
    });
    client.test("All sub-bookings are CONFIRMED", function () {
        client.assert(response.body.flight.status === "CONFIRMED", "Expected flight CONFIRMED");
        client.assert(response.body.hotel.status === "CONFIRMED", "Expected hotel CONFIRMED");
        client.assert(response.body.car.status === "CONFIRMED", "Expected car CONFIRMED");
    });
%}

### Booking Service - OpenAPI Specification
GET http://{{host}}:{{bookingPort}}/openapi

> {%
    client.test("OpenAPI status is 200", function () {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("OpenAPI response is YAML", function () {
        client.assert(response.contentType.mimeType === "application/yaml", "Expected application/yaml");
    });
%}
